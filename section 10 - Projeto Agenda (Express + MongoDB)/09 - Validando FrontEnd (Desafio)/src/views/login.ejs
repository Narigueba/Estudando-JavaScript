<%- include('includes/head') %>
<%- include('includes/nav') %>

<div class="container">
  <div class="row">
    <div class="col-lg-2">

    </div>

    <div class="col-lg-8 my-3">
      <h1 class="text-center">Criar conta ou Entrar</h1>
      <p class="text-center lead">Faça Login ou crie sua conta abaixo:</p>
      <%- include('includes/messages') %>
    

      <div class="row">
        <div class="col-lg my-5">
          <h4>Faça seu cadastro</h4>
          <p>Crie sua conta agora mesmo preenchendo o formulário:</p>
          <form class="form-cadastro" action="/login/register" method="post">
            <input type="hidden" name="_csrf" value=<%= csrfToken%>>
            <div class="form-group my-3">
              <label>Email</label>
              <input type="email" class="form-control" name="email">
            </div>
            <div class="form-group my-3">
              <label>Senha</label>
              <input type="password" class="form-control" name="password">
            </div>
            <button type="submit" class="btn btn-primary">Criar conta</button>
          </form>
        </div>
        
        <div class="col-lg my-5">
          <h4>Entrar no sistema </h4>
          <p>Entre em sua conta abaixo:</p>
          <form class="form-login" action="/login/login" method="post">
            <input type="hidden" name="_csrf" value=<%= csrfToken%>>
            <div class="form-group my-3">
              <label>Email</label>
              <input type="email" class="form-control" name="email">
            </div>
            <div class="form-group my-3">
              <label>Senha</label>
              <input type="password" class="form-control" name="password">
            </div>
            <button type="submit" class="btn btn-success">Entrar</button>
          </form>
        </div>
      </div>

    <div class="col-lg-2"></div>
  </div>
</div>

<%- include('includes/footer') %>